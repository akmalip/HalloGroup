function fmtCurr(n) {
  if (n === undefined || n === null || isNaN(n)) return '—';
  if (n >= 1000000) return 'SGD ' + (n / 1000000).toFixed(1) + 'M';
  if (n >= 1000) return 'SGD ' + (n / 1000).toFixed(1) + 'k';
  return 'SGD ' + n.toFixed(2);
}

function dchart(id) {
  if (state.charts[id]) { state.charts[id].destroy(); delete state.charts[id]; }
}

function showNoData(tcId) {
  const tc = document.getElementById(tcId);
  if (!tc) return;
  tc.innerHTML = `<div class="no-data"><div class="no-data-icon">📂</div><div class="no-data-title">Belum ada data</div><div class="no-data-sub">Upload file order atau ads di tab "Data Files" untuk melihat analisa ini.</div><button class="btn btn-primary" style="margin-top:14px" onclick="gotoTab('upload')">⬆ Import Data</button></div>`;
}

function setLang(l) {
  state.lang = l;
  document.getElementById('lb-id').classList.toggle('active', l === 'id');
  document.getElementById('lb-en').classList.toggle('active', l === 'en');
}

// ═══════════════════════════════════════════════════════════
// PROJECT CRUD
// ═══════════════════════════════════════════════════════════
function renderProjList() {
  document.getElementById('proj-list').innerHTML = state.projects.map(p => `
    <button class="proj-item${p.id === state.selProject ? ' active' : ''}" onclick="selectProject('${p.id}')">
      <div class="proj-dot" style="background:${p.color}"></div>
      <div class="proj-name">${p.name}</div>
      <span class="proj-month">${p.months?.[0] ? formatMonth(p.months[0]) : '—'}</span>
    </button>`).join('');
}

let selColor = '#FF6B35';

document.querySelectorAll('#np-clr .clr-dot').forEach(d => {
  d.onclick = function() {
    document.querySelectorAll('#np-clr .clr-dot').forEach(x => x.classList.remove('on'));
    this.classList.add('on');
    selColor = this.getAttribute('data-c');
  };
});
document.querySelectorAll('#np-plat .chip').forEach(c => {
  c.onclick = function() { this.classList.toggle('on'); };
});
document.querySelectorAll('#type-chips .chip').forEach(c => {
  c.onclick = function() {
    document.querySelectorAll('#type-chips .chip').forEach(x => x.classList.remove('on'));
    this.classList.add('on');
    state.fileType = this.getAttribute('data-t');
    renderFileList();
  };
});

// Drag and drop
const dz = document.getElementById('drop-zone');
if (dz) {
  dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('drag'); });
  dz.addEventListener('dragleave', () => dz.classList.remove('drag'));
  dz.addEventListener('drop', e => {
    e.preventDefault(); dz.classList.remove('drag');
    const dt = e.dataTransfer;
    if (dt.files.length) handleFiles({ target: { files: dt.files, value: '' } });
  });
}

function createProject() {
  const name = document.getElementById('np-name').value.trim();
  if (!name) { document.getElementById('np-name').focus(); return; }
  const client = document.getElementById('np-client').value.trim();
  const plats = Array.from(document.querySelectorAll('#np-plat .chip.on')).map(c => c.getAttribute('data-p'));
  const np = {
    id: 'p-' + Date.now(),
    name, client,
    color: selColor,
    platform: plats[0] || 'shopee',
    hasData: false,
    months: [],
    gmv: 0,
    orders: 0,
    data: {}
  };
  state.projects.push(np);
  state.selProject = np.id;
  closeModal('modal-np');
  document.getElementById('np-name').value = '';
  document.getElementById('np-client').value = '';
  renderProjList();
  saveToLocalStorage();
  gotoPage('dt');
}

function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
document.getElementById('modal-np').addEventListener('click', function(e) {
  if (e.target === this) closeModal('modal-np');
});

// ═══════════════════════════════════════════════════════════
// PERSISTENCE — localStorage
// ═══════════════════════════════════════════════════════════
function saveToLocalStorage() {
  try {
    // Save projects metadata + parsed data (not raw rows — too large)
    const toSave = state.projects.map(p => ({
      id: p.id, name: p.name, client: p.client, color: p.color,
      platform: p.platform, hasData: p.hasData, hasAds: p.hasAds,
      months: p.months, latestPeriod: p.latestPeriod,
      gmv: p.gmv, orders: p.orders,
      // Save parsed data (not raw rows)
      data: p.data ? Object.fromEntries(
        Object.entries(p.data).map(([period, d]) => [period, {
          gmv: d.gmv, aov: d.aov, completedOrders: d.completedOrders,
          cancelledOrders: d.cancelledOrders, totalUniqueOrders: d.totalUniqueOrders,
          uniqueBuyers: d.uniqueBuyers, newBuyers: d.newBuyers, repeatBuyers: d.repeatBuyers,
          cancelRate: d.cancelRate, sellerDiscount: d.sellerDiscount,
          daily: d.daily, hourMap: d.hourMap, wdayMap: d.wdayMap,
          skus: d.skus, vouchers: d.vouchers, cancelReasons: d.cancelReasons,
          shipMap: d.shipMap, statusCount: d.statusCount, topBuyers: d.topBuyers,
          ordersWithVoucher: d.ordersWithVoucher, uniqueVouchers: d.uniqueVouchers,
        }])
      ) : {},
      // Save parsed ads data
      _adsDataParsed: p._adsDataParsed ? {
        totals: p._adsDataParsed.totals,
        campaigns: p._adsDataParsed.campaigns,
      } : null,
    }));
    localStorage.setItem('ecominsight_projects', JSON.stringify(toSave));
    localStorage.setItem('ecominsight_selProject', state.selProject || '');
  } catch(e) {
    console.warn('localStorage save failed (quota?):', e.message);
  }
}

function loadFromLocalStorage() {
  try {
    const saved = localStorage.getItem('ecominsight_projects');
    if (!saved) return false;
    const projects = JSON.parse(saved);
    if (!projects || !projects.length) return false;
    state.projects = projects;
    state.selProject = localStorage.getItem('ecominsight_selProject') || projects[0]?.id;
    return true;
  } catch(e) {
    console.warn('localStorage load failed:', e);
    return false;
  }
}

// ═══════════════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════════════
const loaded = loadFromLocalStorage();
if (!loaded) {
  initDemoProject();
}
renderProjList();
gotoPage('ov');
renderOvPage();
</script>
