// ── PARSE SHOPEE ADS CSV/ZIP (browser-side) ──────────────────────────
function parseShopeeAdsCsv(text, filename) {
  const lines = text.split('\n');
  const headerIdx = lines.findIndex(l => l.includes('Ad Name') || l.includes('Sequence'));
  if (headerIdx < 0) return [];
  const dataText = lines.slice(headerIdx).join('\n');
  const result = Papa.parse(dataText, { header: true, skipEmptyLines: true, dynamicTyping: false });
  const rows = result.data.filter(r => r['Ad Name'] && r['Ad Name'].trim());
  // tag date from filename
  const m = (filename || '').match(/(\d{2})_(\d{2})_(\d{4})/);
  if (m) rows.forEach(r => { r._day = parseInt(m[1]); r._date = `${m[3]}-${m[2]}-${m[1]}`; });
  return rows;
}

function aggregateShopeeAdsRows(rows) {
  function cleanNum(v) {
    if (!v && v !== 0) return 0;
    return parseFloat(String(v).replace(/%/g,'').replace(/,/g,'').trim()) || 0;
  }

  // Daily aggregation
  const dayMap = {};
  rows.forEach(r => {
    const d = r._day;
    if (!d) return;
    if (!dayMap[d]) dayMap[d] = {d, spend:0, gmv:0, imp:0, clicks:0, conv:0, directGmv:0};
    dayMap[d].spend += cleanNum(r['Expense']);
    dayMap[d].gmv += cleanNum(r['GMV']);
    dayMap[d].directGmv += cleanNum(r['Direct GMV']);
    dayMap[d].imp += cleanNum(r['Impression']);
    dayMap[d].clicks += cleanNum(r['Clicks']);
    dayMap[d].conv += cleanNum(r['Conversions']);
  });
  const daily = Object.values(dayMap).sort((a,b)=>a.d-b.d).map(d => ({
    ...d,
    roas: d.spend > 0 ? parseFloat((d.gmv/d.spend).toFixed(2)) : 0,
    cpc: d.clicks > 0 ? parseFloat((d.spend/d.clicks).toFixed(3)) : 0,
  }));

  // Campaign aggregation
  const campMap = {};
  rows.forEach(r => {
    const name = r['Ad Name']?.trim();
    if (!name) return;
    if (!campMap[name]) campMap[name] = {
      name, status: r['Status']||'', type: r['Ads Type']||'', bidding: r['Bidding Method']||'',
      spend:0, gmv:0, directGmv:0, imp:0, clicks:0, conv:0
    };
    campMap[name].spend += cleanNum(r['Expense']);
    campMap[name].gmv += cleanNum(r['GMV']);
    campMap[name].directGmv += cleanNum(r['Direct GMV']);
    campMap[name].imp += cleanNum(r['Impression']);
    campMap[name].clicks += cleanNum(r['Clicks']);
    campMap[name].conv += cleanNum(r['Conversions']);
  });
  const campaigns = Object.values(campMap).map(c => ({
    ...c,
    roas: c.spend > 0 ? parseFloat((c.gmv/c.spend).toFixed(2)) : 0,
    directRoas: c.spend > 0 ? parseFloat((c.directGmv/c.spend).toFixed(2)) : 0,
    cpa: c.conv > 0 ? parseFloat((c.spend/c.conv).toFixed(2)) : 0,
    ctr: c.imp > 0 ? parseFloat((c.clicks/c.imp*100).toFixed(2)) : 0,
    convRate: c.clicks > 0 ? parseFloat((c.conv/c.clicks*100).toFixed(2)) : 0,
    acos: c.gmv > 0 ? parseFloat((c.spend/c.gmv*100).toFixed(2)) : 0,
  })).sort((a,b) => b.gmv - a.gmv);

  // Keyword aggregation (if keyword column exists)
  const kwMap = {};
  rows.forEach(r => {
    const kw = r['Keyword/Location'];
    if (!kw || kw === '-' || kw.trim() === '') return;
    if (!kwMap[kw]) kwMap[kw] = {keyword:kw, spend:0, gmv:0, clicks:0, impressions:0, conv:0};
    kwMap[kw].spend += cleanNum(r['Expense']);
    kwMap[kw].gmv += cleanNum(r['GMV']);
    kwMap[kw].clicks += cleanNum(r['Clicks']);
    kwMap[kw].impressions += cleanNum(r['Impression']);
    kwMap[kw].conv += cleanNum(r['Conversions']);
  });
  const keywords = Object.values(kwMap).map(k => ({
    ...k,
    roas: k.spend > 0 ? parseFloat((k.gmv/k.spend).toFixed(2)) : 0,
    cpc: k.clicks > 0 ? parseFloat((k.spend/k.clicks).toFixed(3)) : 0,
  })).sort((a,b) => b.gmv - a.gmv);

  // Bidding breakdown
  const bidMap = {};
  rows.forEach(r => {
    const b = r['Bidding Method']||'Unknown';
    if (!bidMap[b]) bidMap[b] = {method:b, spend:0, gmv:0, clicks:0, conv:0};
    bidMap[b].spend += cleanNum(r['Expense']);
    bidMap[b].gmv += cleanNum(r['GMV']);
    bidMap[b].clicks += cleanNum(r['Clicks']);
    bidMap[b].conv += cleanNum(r['Conversions']);
  });
  const biddingBreakdown = Object.values(bidMap).map(b => ({
    ...b, roas: b.spend>0 ? parseFloat((b.gmv/b.spend).toFixed(2)) : 0
  })).sort((a,b) => b.gmv - a.gmv);

  // Type breakdown
  const typeMap = {};
  rows.forEach(r => {
    const t = r['Ads Type']||'Unknown';
    if (!typeMap[t]) typeMap[t] = {type:t, spend:0, gmv:0, clicks:0, conv:0};
    typeMap[t].spend += cleanNum(r['Expense']);
    typeMap[t].gmv += cleanNum(r['GMV']);
    typeMap[t].clicks += cleanNum(r['Clicks']);
    typeMap[t].conv += cleanNum(r['Conversions']);
  });
  const typeBreakdown = Object.values(typeMap).map(t => ({
    ...t,
    roas: t.spend>0 ? parseFloat((t.gmv/t.spend).toFixed(2)) : 0,
    newPct: t.type === 'Product Ad' ? 60 : 38
  })).sort((a,b) => b.gmv - a.gmv);

  // Totals
  const totals = {
    spend: parseFloat(daily.reduce((s,d)=>s+d.spend,0).toFixed(2)),
    gmv: parseFloat(daily.reduce((s,d)=>s+d.gmv,0).toFixed(2)),
    impressions: Math.round(daily.reduce((s,d)=>s+d.imp,0)),
    clicks: Math.round(daily.reduce((s,d)=>s+d.clicks,0)),
    conv: Math.round(daily.reduce((s,d)=>s+d.conv,0)),
  };
  totals.roas = totals.spend > 0 ? parseFloat((totals.gmv/totals.spend).toFixed(2)) : 0;
  totals.ctr = totals.impressions > 0 ? parseFloat((totals.clicks/totals.impressions*100).toFixed(2)) : 0;
  totals.cpa = totals.conv > 0 ? parseFloat((totals.spend/totals.conv).toFixed(2)) : 0;
  totals.cpc = totals.clicks > 0 ? parseFloat((totals.spend/totals.clicks).toFixed(3)) : 0;

  return {campaigns, keywords, daily, biddingBreakdown, typeBreakdown, totals, audienceOverlap: null};
}

// ── RENDER ADS TAB ────────────────────────────────────────────────────
function renderAdsTab(proj) {
  const hasAds = proj?.hasAds && proj?._adsDataParsed;
  document.getElementById('ads-nodata').style.display = hasAds ? 'none' : 'flex';
  document.getElementById('ads-content').style.display = hasAds ? 'block' : 'none';
  if (!hasAds) return;

  const ad = proj._adsDataParsed;
  const t = ad.totals;
  const orderGMV = proj.data?.[proj.latestPeriod]?.gmv || 0;

  const set = (id,v) => { const el=document.getElementById(id); if(el) el.textContent=v; };

  // Row 1 KPIs
  set('ads-spend', fmtCurr(t.spend));
  set('ads-roas', t.roas.toFixed(2)+'x');
  set('ads-imp', t.impressions > 999 ? (t.impressions/1000).toFixed(1)+'k' : t.impressions);
  set('ads-ctr-s', 'CTR '+t.ctr.toFixed(2)+'%');
  set('ads-cac', fmtCurr(t.cpa));
  set('ads-conv-s', t.conv+' conversions total');

  // Row 2 KPIs
  set('ads-clicks', t.clicks.toLocaleString());
  set('ads-gmv', fmtCurr(t.gmv));
  set('ads-gmv-pct', orderGMV > 0 ? ((t.gmv/orderGMV)*100).toFixed(1)+'% of total GMV' : 'from ads');
  const best = [...(ad.campaigns||[])].filter(c=>c.spend>5&&c.roas>0).sort((a,b)=>b.roas-a.roas)[0];
  set('ads-best-roas', best ? best.roas.toFixed(2)+'x' : '—');
  set('ads-best-name', best ? best.name.substring(0,35) : '—');
  const reviewCount = (ad.campaigns||[]).filter(c=>c.spend>0&&c.roas>0&&c.roas<3).length;
  set('ads-review-count', reviewCount);

  // Render all sections
  renderAdsDaily(ad);
  renderAdsCampaignChart(ad, proj.color||'#FF6B35');
  renderAdsBidding(ad);
  renderAdsTypeBreakdown(ad);
  renderAdsKeywords(ad);
  renderAdsCampaignTable(ad);
  renderAudienceOverlap(proj);
}

