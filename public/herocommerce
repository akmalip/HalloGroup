// ═══════════════════════════════════════════════════════════
// DATA ENGINE — parse raw Shopee order file
// ═══════════════════════════════════════════════════════════
function parseOrderData(rows) {
  // rows = array of objects with column headers as keys
  const completed = rows.filter(r => r['Order Status'] === 'Completed');
  const cancelled = rows.filter(r => r['Order Status'] === 'Cancelled');
  const all = rows;

  // Unique orders (one row per SKU per order, so dedup by Order ID)
  const orderMap = {};
  completed.forEach(r => {
    const id = r['Order ID'];
    if (!orderMap[id]) orderMap[id] = r;
    else {
      // accumulate Total Amount only once per order
    }
  });
  const orders = Object.values(orderMap);

  // GMV = sum of Total Amount (per unique order)
  const gmv = orders.reduce((s, r) => s + (parseFloat(r['Total Amount']) || 0), 0);
  const aov = orders.length > 0 ? gmv / orders.length : 0;

  // Unique buyers
  const buyerOrders = {};
  orders.forEach(r => {
    const u = r['Username (Buyer)'] || r['Receiver Name'] || 'unknown';
    if (!buyerOrders[u]) buyerOrders[u] = [];
    buyerOrders[u].push(r);
  });
  const buyers = Object.keys(buyerOrders);
  const newBuyers = buyers.filter(b => buyerOrders[b].length === 1);
  const repeatBuyers = buyers.filter(b => buyerOrders[b].length > 1);

  // Cancellation
  const totalOrders = (rows.filter(r => {
    const s = r['Order Status'] || '';
    return s && !s.startsWith('Order Received');
  }).map(r => r['Order ID']));
  const uniqueTotal = [...new Set(totalOrders)].length;

  // Daily orders
  const dailyMap = {};
  orders.forEach(r => {
    const dt = r['Order Creation Date'] || r['Order Paid Time'] || '';
    const day = dt ? dt.toString().split(' ')[0] : 'unknown';
    if (!dailyMap[day]) dailyMap[day] = { orders: 0, gmv: 0 };
    dailyMap[day].orders++;
    dailyMap[day].gmv += parseFloat(r['Total Amount']) || 0;
  });
  const daily = Object.entries(dailyMap).map(([d, v]) => ({
    date: d, day: parseInt(d.split('-')[2]) || parseInt(d.split('/')[2]) || 0,
    orders: v.orders, gmv: parseFloat(v.gmv.toFixed(2))
  })).sort((a, b) => a.day - b.day);

  // Hour distribution
  const hourMap = {};
  orders.forEach(r => {
    const dt = r['Order Creation Date'] || '';
    const h = dt ? parseInt(dt.toString().split(' ')[1]?.split(':')[0]) : -1;
    if (h >= 0) hourMap[h] = (hourMap[h] || 0) + 1;
  });

  // Weekday
  const wdayMap = {};
  const WD = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  orders.forEach(r => {
    const dt = r['Order Creation Date'] || r['Order Paid Time'] || '';
    if (dt) {
      try {
        const d = new Date(dt.toString().replace(' ', 'T'));
        if (!isNaN(d)) { const wd = WD[d.getDay()]; wdayMap[wd] = (wdayMap[wd] || 0) + 1; }
      } catch(e) {}
    }
  });

  // SKU analysis (use all completed rows, not deduplicated)
  const skuMap = {};
  completed.forEach(r => {
    const sku = r['Parent SKU Reference No.'] || r['SKU Reference No.'] || 'Unknown';
    const name = r['Product Name'] || sku;
    if (!skuMap[sku]) skuMap[sku] = { sku, name, qty: 0, revenue: 0, orderIds: new Set(), returns: 0 };
    skuMap[sku].qty += parseInt(r['Quantity']) || 0;
    skuMap[sku].revenue += parseFloat(r['Total Buyer Payment']) || 0;
    skuMap[sku].orderIds.add(r['Order ID']);
    if (r['Return / Refund Status'] && r['Return / Refund Status'].trim()) skuMap[sku].returns++;
  });
  const skus = Object.values(skuMap).map(s => ({ ...s, orders: s.orderIds.size, avgPrice: s.orders > 0 ? s.revenue / s.qty : 0 })).sort((a, b) => b.revenue - a.revenue);

  // Vouchers
  const voucherMap = {};
  const ordersWithVoucher = new Set();
  completed.forEach(r => {
    const vc = r['Voucher Code'] || '';
    if (vc && vc.trim()) {
      vc.split(';').forEach(code => {
        code = code.trim();
        if (code && !code.startsWith('FSV') && !code.startsWith('ROI3') && code.length > 2) {
          voucherMap[code] = (voucherMap[code] || 0) + 1;
          ordersWithVoucher.add(r['Order ID']);
        }
      });
    }
  });
  const allVouchersMap = {};
  completed.forEach(r => {
    const vc = r['Voucher Code'] || '';
    if (vc && vc.trim()) vc.split(';').forEach(c => { c = c.trim(); if (c) allVouchersMap[c] = (allVouchersMap[c] || 0) + 1; });
  });
  const vouchers = Object.entries(voucherMap).map(([c, u]) => ({ code: c, uses: u })).sort((a, b) => b.uses - a.uses);

  // Seller discount
  const sellerDiscount = orders.reduce((s, r) => s + (parseFloat(r['Seller Discount']) || 0), 0);

  // Cancel reasons
  const cancelReasons = {};
  cancelled.forEach(r => {
    const reason = r['Cancel reason'] || 'Unknown';
    const shortReason = reason.length > 60 ? reason.substring(0, 57) + '...' : reason;
    cancelReasons[shortReason] = (cancelReasons[shortReason] || 0) + 1;
  });

  // Shipping
  const shipMap = {};
  orders.forEach(r => {
    const s = (r['Shipping Option'] || '').split('-')[0].trim() || 'Other';
    shipMap[s] = (shipMap[s] || 0) + 1;
  });

  // Status
  const statusMap = {};
  rows.forEach(r => {
    const id = r['Order ID'];
    let s = r['Order Status'] || 'Unknown';
    if (s.startsWith('Order Received')) s = 'Pending Return';
    if (!statusMap[id]) statusMap[id] = s;
  });
  const statusCount = {};
  Object.values(statusMap).forEach(s => statusCount[s] = (statusCount[s] || 0) + 1);

  // Top buyers
  const topBuyers = repeatBuyers.map(u => {
    const bOrders = buyerOrders[u];
    const spent = bOrders.reduce((s, r) => s + (parseFloat(r['Total Amount']) || 0), 0);
    const skuFreq = {};
    completed.filter(r => r['Username (Buyer)'] === u).forEach(r => {
      const p = r['Parent SKU Reference No.'] || 'N/A';
      skuFreq[p] = (skuFreq[p] || 0) + 1;
    });
    const topProd = Object.entries(skuFreq).sort((a, b) => b[1] - a[1])[0]?.[0] || 'N/A';
    return { username: u, orders: bOrders.length, spent, topProduct: topProd };
  }).sort((a, b) => b.orders - a.orders || b.spent - a.spent).slice(0, 10);

  return {
    gmv, aov,
    completedOrders: orders.length,
    cancelledOrders: [...new Set(cancelled.map(r => r['Order ID']))].length,
    totalUniqueOrders: uniqueTotal,
    uniqueBuyers: buyers.length,
    newBuyers: newBuyers.length,
    repeatBuyers: repeatBuyers.length,
    cancelRate: uniqueTotal > 0 ? (([...new Set(cancelled.map(r => r['Order ID']))].length / uniqueTotal) * 100) : 0,
    daily, hourMap, wdayMap,
    skus, vouchers,
    sellerDiscount,
    cancelReasons,
    shipMap, statusCount,
    topBuyers,
    ordersWithVoucher: ordersWithVoucher.size,
    uniqueVouchers: Object.keys(voucherMap).length,
    raw: { completed, cancelled, orders }
  };
}

// ═══════════════════════════════════════════════════════════
// FILE HANDLING
// ═══════════════════════════════════════════════════════════
function handleFiles(e) {
  const files = Array.from(e.target.files);
  if (!files.length) return;

  files.forEach(file => {
    const ext = file.name.split('.').pop().toLowerCase();
    if (ext === 'zip') {
      processZipFile(file);
    } else {
      processSingleFile(file);
    }
  });
  e.target.value = '';
}

async function processZipFile(file) {
  const type = document.querySelector('#type-chips .chip.on')?.getAttribute('data-t') || 'marketplace';
  try {
    const zip = await JSZip.loadAsync(file);
    const csvFiles = [];
    zip.forEach((path, zipEntry) => {
      if (!zipEntry.dir && !path.includes('__MACOSX') && !path.includes('.DS_Store')) {
        const ext = path.split('.').pop().toLowerCase();
        if (['csv','xlsx','xls'].includes(ext)) csvFiles.push({ path, entry: zipEntry, ext });
      }
    });

    if (csvFiles.length === 0) { alert('No CSV/Excel files found in ZIP'); return; }

    const fileObj = { name: file.name + ` (${csvFiles.length} files)`, size: file.size, type, rows: [], rowCount: 0 };
    state.uploadedFiles.push(fileObj);
    renderFileList();

    const allRows = [];
    for (const cf of csvFiles.sort((a,b) => a.path.localeCompare(b.path))) {
      const content = await cf.entry.async('text');
      // Use our unified parser which handles Shopee header offset
      const rows = parseShopeeAdsCsv(content, cf.path);
      allRows.push(...rows);
    }

    fileObj.rows = allRows;
    fileObj.rowCount = allRows.length;

    const proj = state.projects.find(p => p.id === state.selProject);
    if (proj && allRows.length > 0) {
      if (type === 'orders') {
        const parsed = parseOrderData(allRows);
        if (!proj.data) proj.data = {};
        const period = guessPeriod(file.name, allRows);
        proj.data[period] = parsed;
        proj.latestPeriod = period;
        proj.gmv = parsed.gmv;
        proj.orders = parsed.completedOrders;
        proj.hasData = true;
        if (!proj.months) proj.months = [];
        if (!proj.months.includes(period)) proj.months.unshift(period);
      } else {
        // Ads data — parse immediately into structured format
        if (!proj.adsData) proj.adsData = {};
        proj.adsData[type] = allRows;
        proj.hasAds = true;
        proj._adsDataParsed = aggregateShopeeAdsRows(allRows);
      }
    }

    saveToLocalStorage();
    renderFileList();
    renderProjList();
    renderTopbar();
    if (type === 'orders') { renderKPITab(); }
    else { setTimeout(() => gotoTab('ads'), 300); }
  } catch(err) {
    alert('Error reading ZIP: ' + err.message);
  }
}


function processSingleFile(file) {
  const ext = file.name.split('.').pop().toLowerCase();
  const type = document.querySelector('#type-chips .chip.on')?.getAttribute('data-t') || 'orders';
  const reader = new FileReader();

  reader.onload = function(ev) {
    try {
      let rows = [];
      const rawText = ext === 'csv' ? ev.target.result : null;

      if (ext === 'csv') {
        const firstLine = rawText.split('\n')[0] || '';
        if (firstLine.includes('CPC Ads Report') || firstLine.includes('Shopee')) {
          const dataLines = rawText.split('\n').slice(7).join('\n');
          const result = Papa.parse(dataLines, { header: true, skipEmptyLines: true, dynamicTyping: false });
          rows = result.data.filter(r => r['Ad Name'] || r['Sequence']);
        } else {
          const result = Papa.parse(rawText, { header: true, skipEmptyLines: true });
          rows = result.data;
        }
      } else {
        const wb = XLSX.read(ev.target.result, { type: 'array', cellDates: false });
        const sn = wb.SheetNames.includes('orders') ? 'orders' : wb.SheetNames[0];
        rows = XLSX.utils.sheet_to_json(wb.Sheets[sn], { defval: '' });
      }

      const fileObj = { name: file.name, size: file.size, type, rows, rowCount: rows.length };
      const proj = state.projects.find(p => p.id === state.selProject);

      if (type === 'orders' && rows.length > 0) {
        const parsed = parseOrderData(rows);
        if (proj) {
          if (!proj.data) proj.data = {};
          const period = guessPeriod(file.name, rows);
          proj.data[period] = parsed;
          proj.latestPeriod = period;
          proj.gmv = parsed.gmv;
          proj.orders = parsed.completedOrders;
          proj.hasData = true;
          if (!proj.months) proj.months = [];
          if (!proj.months.includes(period)) proj.months.unshift(period);
        }
      } else if (type !== 'orders') {
        if (proj) {
          if (!proj.adsData) proj.adsData = {};
          proj.adsData[type] = rows;
          proj.hasAds = true;
          proj._adsDataParsed = aggregateShopeeAdsRows(rows);
        }
      }

      state.uploadedFiles.push(fileObj);
      saveToLocalStorage();
      renderFileList();
      renderProjList();
      renderTopbar();
      if (type === 'orders') renderKPITab();
      if (['marketplace','meta','tiktok','google'].includes(type)) {
        setTimeout(() => gotoTab('ads'), 300);
      }
    } catch(err) {
      alert('Error reading file: ' + err.message + '\n\nTip: pastikan file tidak sedang dibuka di Excel.');
    }
  };

  if (ext === 'csv') reader.readAsText(file);
  else reader.readAsArrayBuffer(file);
}

function guessPeriod(filename, rows) {
  // Try to extract period from filename
  const m = filename.match(/(\d{4})(\d{2})/);
  if (m) return m[1] + '-' + m[2];
  // Try from data
  if (rows.length > 0) {
    const dt = rows[0]['Order Creation Date'] || rows[0]['Order Paid Time'] || '';
    const dm = dt.toString().match(/(\d{4})-(\d{2})/);
    if (dm) return dm[1] + '-' + dm[2];
  }
  return new Date().toISOString().slice(0, 7);
}

function renderFileList() {
  const list = document.getElementById('file-list');
  const proj = state.projects.find(p => p.id === state.selProject);
  const period = proj?.latestPeriod || '—';
  document.getElementById('loaded-period').textContent = period;

  if (state.uploadedFiles.length === 0) {
    list.innerHTML = '<div style="text-align:center;padding:20px;color:var(--t3);font-size:12px">No files loaded yet</div>';
    return;
  }

  const typeColors = { orders: '#0A8F5C', meta: '#1877F2', tiktok: '#000', google: '#EA4335', marketplace: '#FF6B35', customer: '#6830D1' };
  list.innerHTML = state.uploadedFiles.map((f, i) => `
    <div style="display:flex;align-items:center;gap:10px;padding:9px 12px;background:var(--bg3);border-radius:var(--rs);margin-bottom:7px;border:1px solid var(--border)">
      <span style="font-size:18px">📄</span>
      <div style="flex:1;min-width:0">
        <div style="font-weight:700;color:var(--text);font-size:12px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${f.name}</div>
        <div style="font-size:10px;color:var(--t3)">${f.type} · ${f.rowCount} rows · ${(f.size/1024).toFixed(0)} KB</div>
      </div>
      <span class="pill" style="background:${typeColors[f.type]}22;color:${typeColors[f.type]};font-size:9px">${f.type}</span>
      <span class="pill pg">✓ Parsed</span>
      <button onclick="removeFile(${i})" style="background:none;border:none;color:var(--t3);cursor:pointer;font-size:14px;padding:0 4px">×</button>
    </div>`).join('');

  // DQ Report
  const dq = document.getElementById('dq-report');
  const ord = state.uploadedFiles.filter(f => f.type === 'orders');
  if (ord.length > 0) {
    const f = ord[0];
    const rows = f.rows;
    const withBuyer = rows.filter(r => r['Username (Buyer)'] && r['Username (Buyer)'].trim()).length;
    const withVoucher = rows.filter(r => r['Voucher Code'] && r['Voucher Code'].trim()).length;
    const withGMV = rows.filter(r => parseFloat(r['Total Amount']) > 0).length;
    dq.innerHTML = `
      <div class="stat-row"><span style="color:var(--t2)">Total rows parsed</span><span class="num">${rows.length}</span></div>
      <div class="stat-row"><span style="color:var(--t2)">Rows with buyer username</span><span><span class="pill pg">${withBuyer}</span></span></div>
      <div class="stat-row"><span style="color:var(--t2)">Rows with voucher code</span><span class="num">${withVoucher} (${((withVoucher/rows.length)*100).toFixed(0)}%)</span></div>
      <div class="stat-row"><span style="color:var(--t2)">Rows with GMV > 0</span><span class="pill pg">${withGMV} / ${rows.length}</span></div>
      <div class="stat-row"><span style="color:var(--t2)">Data quality score</span><span class="pill pg">Good — ${((withBuyer/rows.length)*100).toFixed(1)}%</span></div>`;
  }

  // Schema reference
  const typeSchemas = {
    orders: ['Order ID','Order Status','Cancel reason','Order Creation Date','Username (Buyer)','Total Amount','Grand Total','Quantity','Deal Price','Original Price','Voucher Code','Seller Discount','Shipping Option','Parent SKU Reference No.','Product Name'],
    meta: ['Date','Campaign name','Ad Set Name','Amount spent','Impressions','Clicks','Purchases','Purchase ROAS','Cost per purchase'],
    tiktok: ['Date','Campaign Name','Ad Group Name','Cost','Impressions','Clicks','Conversions','ROAS'],
    google: ['Day','Campaign','Ad group','Cost','Impressions','Clicks','Conversions','Conv. value'],
    marketplace: ['Date','Campaign Name','Budget','Spend','Clicks','Orders','GMV'],
    customer: ['buyer_id','first_order_date','total_orders','total_spent','last_order_date'],
  };
  const activeType = document.querySelector('#type-chips .chip.on')?.getAttribute('data-t') || 'orders';
  const schema = typeSchemas[activeType] || typeSchemas.orders;
  document.getElementById('schema-ref').innerHTML = `
    <div style="display:flex;flex-wrap:wrap;gap:5px">
      ${schema.map(c => `<span style="background:var(--bl);color:var(--blue);font-family:var(--mono);font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px">${c}</span>`).join('')}
    </div>
    <div style="margin-top:9px;font-size:11px;color:var(--t3);line-height:1.6">
      Nama kolom tidak harus persis sama — sistem auto-detect berdasarkan similarity. Semakin mirip nama kolom, semakin akurat hasilnya.
    </div>`;
}

function removeFile(i) {
  state.uploadedFiles.splice(i, 1);
  renderFileList();
}

