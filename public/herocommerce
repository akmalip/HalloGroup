  if (!proj?.hasData) { alert('No data to export'); return; }
  const data = proj?.data?.[proj?.latestPeriod];
  if (!data) return;

  const wb = XLSX.utils.book_new();

  // KPI Sheet
  const kpiRows = [
    ['Metric', 'Value'],
    ['Period', proj.latestPeriod],
    ['Project', proj.name],
    ['GMV (Total Amount)', data.gmv],
    ['Completed Orders', data.completedOrders],
    ['Cancelled Orders', data.cancelledOrders],
    ['Total Unique Orders', data.totalUniqueOrders],
    ['Cancellation Rate (%)', data.cancelRate.toFixed(2)],
    ['AOV', data.aov.toFixed(2)],
    ['Unique Buyers', data.uniqueBuyers],
    ['New Buyers', data.newBuyers],
    ['Repeat Buyers', data.repeatBuyers],
    ['Repeat Purchase Rate (%)', ((data.repeatBuyers/data.uniqueBuyers)*100).toFixed(2)],
    ['Orders with Voucher', data.ordersWithVoucher],
    ['Total Seller Discount', data.sellerDiscount.toFixed(2)],
  ];
  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(kpiRows), 'KPI Summary');

  // Daily Sheet
  const dailyRows = [['Date', 'Day', 'Orders', 'GMV']].concat(data.daily.map(d => [d.date, d.day, d.orders, d.gmv]));
  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(dailyRows), 'Daily Data');

  // Products Sheet
  const prodRows = [['SKU', 'Product Name', 'Qty Sold', 'Revenue', 'Orders', 'Avg Price', 'Returns']].concat(
    data.skus.map(s => [s.sku, s.name, s.qty, s.revenue.toFixed(2), s.orders, s.avgPrice.toFixed(2), s.returns])
  );
  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(prodRows), 'Products');

  // Vouchers Sheet
  const vRows = [['Voucher Code', 'Uses']].concat(data.vouchers.map(v => [v.code, v.uses]));
  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(vRows), 'Vouchers');

  // Top Buyers Sheet
  const buyerRows = [['Username', 'Orders', 'Total Spent', 'Top Product']].concat(
    data.topBuyers.map(b => [b.username, b.orders, b.spent.toFixed(2), b.topProduct])
  );
  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(buyerRows), 'Top Buyers');

  XLSX.writeFile(wb, `EcomInsight_${proj.name.replace(/[^a-z0-9]/gi,'_')}_${proj.latestPeriod}.xlsx`);
}

