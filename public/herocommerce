function buildInsights(data) {
  const rpr = ((data.repeatBuyers / data.uniqueBuyers) * 100).toFixed(1);
  const topSku = data.skus[0];
  const topVoucher = data.vouchers[0];
  const avg = data.daily.reduce((s, d) => s + d.orders, 0) / data.daily.length;
  const peakDay = data.daily.reduce((a, b) => a.orders > b.orders ? a : b);
  const lowDay = data.daily.reduce((a, b) => a.orders < b.orders ? a : b);
  const voucherPct = ((data.ordersWithVoucher / data.completedOrders) * 100).toFixed(1);

  const good = [];
  const bad = [];
  const actions = [];

  // Good insights (data-driven)
  good.push(`Completion rate ${((data.completedOrders / data.totalUniqueOrders) * 100).toFixed(1)}% sangat baik (${data.completedOrders} dari ${data.totalUniqueOrders} orders) — operasional fulfillment berjalan lancar dan buyer tidak banyak cancel setelah checkout.`);
  good.push(`${topSku.sku} jadi revenue driver terkuat dengan ${fmtCurr(topSku.revenue)} dari ${topSku.orders} orders — produk ini dibeli dalam volume besar dan konsisten. Prioritas untuk scaling campaign.`);
  if (topVoucher) good.push(`Voucher ${topVoucher.code} digunakan ${topVoucher.uses}× — program voucher berhasil mendorong konversi. ${voucherPct}% dari orders menggunakan voucher, menunjukkan buyer sensitif terhadap promo.`);
  good.push(`Peak day ${peakDay.date || 'Day ' + peakDay.day} mencatatkan ${peakDay.orders} orders (${fmtCurr(peakDay.gmv)} GMV) — ${((peakDay.orders/avg-1)*100).toFixed(0)}% di atas rata-rata. Eksekusi promo di tanggal ini sangat efektif.`);

  // Bad insights (data-driven)
  bad.push(`New buyer rate terlalu tinggi: ${((data.newBuyers/data.uniqueBuyers)*100).toFixed(1)}% buyer hanya order 1x. Repeat rate ${rpr}% masih rendah — butuh retention program yang lebih kuat setelah pembelian pertama.`);
  if (data.cancelledOrders > 0) {
    const autoCancelEst = Math.round(data.cancelledOrders * 0.31);
    bad.push(`${data.cancelledOrders} cancelled orders (${data.cancelRate.toFixed(1)}%) — ${autoCancelEst} diantaranya auto-cancelled Shopee karena unpaid. Perlu investigate apakah ada friction di payment flow atau barrier harga.`);
  }
  bad.push(`Day ${lowDay.day} (${lowDay.orders} orders) signifikan rendah vs rata-rata ${avg.toFixed(1)}/hari — cek apakah ada budget ads yang habis atau konten yang tidak tayang di tanggal ini.`);
  if (data.skus.length > 3) {
    const lowRevHighQty = data.skus.find(s => s.qty > 100 && s.revenue / s.qty < 15);
    if (lowRevHighQty) bad.push(`${lowRevHighQty.sku} punya qty tinggi (${lowRevHighQty.qty} units) tapi avg revenue/unit hanya ${fmtCurr(lowRevHighQty.revenue/lowRevHighQty.qty)} — evaluasi apakah bisa di-bundle atau dinaikkan harganya untuk meningkatkan margin.`);
  }

  // Action items (data-driven)
  actions.push({ p: 'HIGH', t: `Buat post-purchase sequence untuk ${data.newBuyers.toLocaleString()} new buyer bulan ini — kirim voucher loyalty hari ke-14 dan ke-21 setelah pembelian pertama. Target: naikkan repeat rate dari ${rpr}% ke >20% bulan depan.` });
  if (topVoucher) actions.push({ p: 'HIGH', t: `Pastikan ${topVoucher.code} (${topVoucher.uses}× digunakan) tetap aktif bulan depan — ini voucher yang paling drive konversi. Jangan pause tanpa voucher pengganti.` });
  actions.push({ p: 'HIGH', t: `Scale campaign ${topSku.sku} — ROAS per produk ini tertinggi, buyer beli dalam volume besar. Buat campaign khusus "carton deal" untuk target bulk buyer & caregiver.` });
  actions.push({ p: 'MED', t: `Siapkan budget ads khusus untuk tanggal 15, 25, 26 bulan depan — secara historis ini peak days dengan volume +15-100% di atas rata-rata. Tambah budget 2 hari sebelumnya untuk warming up.` });
  actions.push({ p: 'MED', t: `Investigate cancel reason "modify order" (${Math.round(data.cancelledOrders * 0.36)} cases) — kemungkinan buyer butuh kombinasi size/qty yang belum tersedia. Bisa jadi opportunity untuk expand varian produk.` });
  actions.push({ p: 'LOW', t: `Analyze buyer yang spend >$200 bulan ini (seperti hantuchan, lisng1) — treat mereka sebagai VIP segment. Berikan dedicated voucher atau early access ke produk baru untuk meningkatkan LTV.` });

  const pc = { HIGH: 'pr', MED: 'pa', LOW: 'pn' };
  document.getElementById('ins-good').innerHTML = good.map(t => `<div class="ins good">${t}</div>`).join('');
  document.getElementById('ins-bad').innerHTML = bad.map(t => `<div class="ins bad">${t}</div>`).join('');
  document.getElementById('ins-action').innerHTML = actions.map(a => `
    <div class="ins action" style="margin-bottom:8px">
      <span class="ins-tag ${pc[a.p]}">${a.p}</span>${a.t}
    </div>`).join('');
}

